# TCC-IRoNL Configuration

# LLM Provider API Keys (at least one required)
# Uncomment and set the provider you want to use:

# OpenAI (GPT-4o, GPT-4, GPT-3.5)
OPENAI_API_KEY=sk-your-openai-key-here

# Google (Gemini Pro)
# GEMINI_API_KEY=your-gemini-key-here

# DeepSeek
# DEEPSEEK_API_KEY=your-deepseek-key-here

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Local Model (Llama-2-7B) - no API key needed, but requires local GPU
# USE_LOCAL_LLM=true
# LOCAL_LLM_PATH=/path/to/llama-2-7b-chat

# SAM Model Configuration
SAM_MODEL_TYPE=vit_b
SAM_MODEL_PATH=./models/sam_vit_b_01ec64.pth

# ROS Configuration
ROS_MASTER_URI=http://localhost:11311
ROS_HOSTNAME=localhost

# Robot Configuration
ROBOT_TYPE=go1  # Options: go1, romr, custom
SIMULATION=true

# Logging
LOG_LEVEL=INFO
